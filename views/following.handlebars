{{! TODO: This page's style need to be improved, maybe we can do two columns. Add a now list CSS class }}

<section>
  <h1>Following</h1>
  <p class='muted'>People you follow and whose posts affect your
    recommendations.</p>

  <div class='list'>
    {{#each following}}
      <div class='card list-item'>
        <div>
          <h2><a href='/profile/{{id}}'>{{name}}</a></h2>
          <p class='muted'>Sport Interests: {{sports}}</p>
        </div>
        {{!-- <button class='btn btn-outline small unpressable'>{{status}}</button> --}}
      </div>
    {{/each}}
  </div>
</section>
<br>
<br>
<section>
  <h1>Blocked Users</h1>
  <p class="muted">People you have blocked and whose posts will not appear in your feed.</p>
  {{#each blocked}}
    <div class='card list-item'>
      <h2><a href='/profile/{{id}}'>{{name}}</a></h2>
    </div>
  {{/each}}
</section>

{{#if error}}
  <p class="text-danger">{{message}}</p>
{{/if}}