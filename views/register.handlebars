<section class="auth-wrapper">
  <div class="card auth-card large">
    <h1>Create Account</h1>
    <p class="muted">Join the sports community and meet people with similar interests.</p>

    <form class="form">
      <div class="grid-2">
        <label>Full Name
          <input type="text" placeholder="Your name" required />
        </label>

        <label>Username
          <input type="text" placeholder="@username" required />
        </label>
      </div>

      <div class="grid-2">
        {{!-- * Now it's browser's own validation --}}
        <label>Email
          <input type="email" placeholder="Email address" required />
        </label>
        {{!-- TODO: Password JS --}}
        <label>Password
          <input type="password" placeholder="Create password" required />
        </label>
      </div>

      <div class="grid-3">
        {{!-- ! This age need to be validated --}}
        <label>Age
          <input type="number" placeholder="18" />
        </label>

        <label>Gender
          <select>
            <option>Male</option>
            <option>Female</option>
            <option>Non-binary</option>
            <option>Prefer not to say</option>
          </select>
        </label>

        <label>Skill Level
          <select>
            <option>Beginner</option>
            <option>Intermediate</option>
            <option>Advanced</option>
          </select>
        </label>
      </div>

      <div class="grid-2">
        <label>City
          <input type="text" placeholder="New York" />
        </label>

        <label>State
          <input type="text" placeholder="NY" />
        </label>
      </div>
  {{!-- TODO: JS validation, auto jump to next step --}}
      <button type="submit" class="btn full">Create Account</button>
    </form>

    <p class="form-note">
      Next step: <a href="/profile/interest-setup">Set your interests</a>
    </p>
  </div>
</section>