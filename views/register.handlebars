<a
  href='/profile/login'
  class='auth-back-arrow page-transition-link'
  aria-label='Back to login page'
></a>

<section class='auth-wrapper'>
  <div class='card auth-card large'>
    <h1>Create Account</h1>
    <p class='muted'>Join the sports community and meet people with similar
      interests.</p>

    <form class='form' method='POST' action='/profile/register'>
      <div class='grid-2'>
        <label>First Name
          <input
            type='text'
            name='firstName'
            placeholder='First name'
            value='{{prev.firstName}}'
            required
          />
        </label>

        <label>Last Name
          <input
            type='text'
            name='lastName'
            placeholder='Last name'
            value='{{prev.lastName}}'
            required
          />
        </label>
      </div>

      <div class='grid-2'>
        <label>Email
          <input
            type='email'
            name='email'
            placeholder='Email address'
            value='{{prev.email}}'
            required
          />
        </label>

        <label>Password
          <input
            type='password'
            name='password'
            placeholder='Create password'
            value='{{prev.password}}'
            required
          />
        </label>
      </div>

      <div class='grid-3'>
        <label>Age
          <input
            type='number'
            name='age'
            placeholder='18'
            value='{{prev.age}}'
          />
        </label>

        <label>Gender
          <select name='gender'>
            {{#if prev.m}}
              <option value='male' selected>Male</option>
            {{else}}
              <option value='male'>Male</option>
            {{/if}}

            {{#if prev.f}}
              <option value='female' selected>Female</option>
            {{else}}
              <option value='female'>Female</option>
            {{/if}}

            {{#if prev.o}}
              <option value='other' selected>Other</option>
            {{else}}
              <option value='other'>Other</option>
            {{/if}}
          </select>
        </label>

        <label>Skill Level
          <select name='skill'>
            {{#if prev.b}}
              <option value='beginner' selected>Beginner</option>
            {{else}}
              <option value='beginner'>Beginner</option>
            {{/if}}

            {{#if prev.i}}
              <option value='intermediate' selected>Intermediate</option>
            {{else}}
              <option value='intermediate'>Intermediate</option>
            {{/if}}

            {{#if prev.a}}
              <option value='advanced' selected>Advanced</option>
            {{else}}
              <option value='advanced'>Advanced</option>
            {{/if}}
          </select>
        </label>
      </div>

      <div class='grid-2'>
        <label>City
          <input
            type='text'
            name='city'
            placeholder='New York'
            value='{{prev.city}}'
          />
        </label>

        <label>State
          <input
            type='text'
            name='state'
            placeholder='NY'
            value='{{prev.state}}'
          />
        </label>
      </div>

      <button type='submit' class='btn full'>Create Account</button>
    </form>

    {{#if error}}
      <p id='errmess2'>{{message}}</p>
    {{/if}}

    <p class='form-note'>
      Don't forget to add your bio and sport interests after registration to get
      better matches!
    </p>
  </div>
</section>