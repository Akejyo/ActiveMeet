<section class="card">
  <h1>Create a New Post</h1>
  <p class="muted">Organize a sports activity and invite the community to join.</p>

  <form class="form">
    <label>Post Title
      <input type="text" placeholder="e.g. Saturday Basketball 5v5" required />
    </label>

    <div class="grid-2">
      <label>Sport Type
        <select>
          <option>Basketball</option>
          <option>Running</option>
          <option>Hiking</option>
          <option>Soccer</option>
          <option>Tennis</option>
        </select>
      </label>

      <label>Location
        <input type="text" placeholder="Enter location" />
      </label>
    </div>

    <div class="grid-3">
      <label>Date
        <input type="date" />
      </label>

      <label>Time
        <input type="time" />
      </label>

      <label>Max Participants
        <input type="number" placeholder="10" />
      </label>
    </div>

    <div class="grid-3">
      <label>Age Restriction
        <input type="text" placeholder="e.g. 18-30" />
      </label>

      <label>Skill Level
        <select>
          <option>Beginner</option>
          <option>Intermediate</option>
          <option>Advanced</option>
          <option>All Levels</option>
        </select>
      </label>

      <label>Gender
        <select>
          <option>Co-ed</option>
          <option>Male only</option>
          <option>Female only</option>
        </select>
      </label>
    </div>

    <label>Description
      <textarea rows="5" placeholder="Describe the activity, expectations, equipment, etc."></textarea>
    </label>

    <button type="submit" class="btn">Publish Post</button>
  </form>
</section>