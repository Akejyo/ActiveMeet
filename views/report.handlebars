<section class="card">
  <h1>Report Content or User</h1>
  <p class="muted">Help us keep the community safe and respectful.</p>

  <form class="form fake-form">
    <label>Report Type
      <select>
        <option>Post</option>
        <option>User</option>
        <option>Chat Message</option>
      </select>
    </label>

    <label>Target ID / Username
      <input type="text" placeholder="e.g. post #12 or @username" />
    </label>

    <label>Reason
      <select>
        <option>Inappropriate Content</option>
        <option>Harassment</option>
        <option>Spam</option>
        <option>Fake Event</option>
        <option>Other</option>
      </select>
    </label>

    <label>Description
      <textarea rows="5" placeholder="Describe the issue..."></textarea>
    </label>

    <button type="submit" class="btn danger">Submit Report</button>
  </form>
</section>